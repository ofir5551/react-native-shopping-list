{
  "permissions": {
    "allow": [
      "Bash(npm start)",
      "Bash(npm run web)",
      "Bash(npm run android)",
      "Bash(npm run ios)",
      "Bash(npm install *)",
      "Bash(npx expo *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git pull *)",
      "Bash(npx supabase *)"
